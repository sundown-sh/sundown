# Sundown configuration. Copy to .env and edit.
#
# Docker Compose (docker-compose.yml) reads this file from the same directory
# as compose.yaml and **requires** SUNDOWN_SECRET_KEY to be set (non-empty)
# before any service starts. If you see
#   required variable SUNDOWN_SECRET_KEY is missing a value
# then `.env` is missing, the key line is commented out, or the value is blank.
#
# Generate a strong key (16+ characters; 32+ recommended):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- Core ---
SUNDOWN_ENV=production
SUNDOWN_LOG_LEVEL=INFO
SUNDOWN_HOST=0.0.0.0
SUNDOWN_PORT=8000

# Database. SQLite by default; for Postgres use:
#   postgresql+psycopg://user:pass@host:5432/sundown
DATABASE_URL=sqlite:///./data/sundown.db

# JWT signing key (HMAC for sessions). CHANGE THIS for every install.
SUNDOWN_SECRET_KEY=change-me-please-this-is-only-for-development
SUNDOWN_JWT_TTL_MINUTES=480
SUNDOWN_REFRESH_TTL_DAYS=14

# --- First-run bootstrap admin (created if no users exist) ---
SUNDOWN_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
SUNDOWN_BOOTSTRAP_ADMIN_PASSWORD=

# --- Scanning ---
SUNDOWN_SCAN_INTERVAL_MINUTES=60
SUNDOWN_DIGEST_HOUR_UTC=14

# --- Notifications (all optional) ---
SUNDOWN_SLACK_WEBHOOK_URL=
SUNDOWN_NOTIFY_EMAIL_FROM=
SUNDOWN_SMTP_HOST=
SUNDOWN_SMTP_PORT=587
SUNDOWN_SMTP_USERNAME=
SUNDOWN_SMTP_PASSWORD=
SUNDOWN_OUTBOUND_WEBHOOK_URL=
SUNDOWN_OUTBOUND_WEBHOOK_SECRET=

# --- Multi-tenant seam (always "default" in OSS build) ---
SUNDOWN_DEFAULT_WORKSPACE=default

# --- Feature flags (comma-separated). Empty means "use defaults". ---
SUNDOWN_FEATURE_FLAGS=
